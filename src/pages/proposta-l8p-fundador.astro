---
import { ViewTransitions } from 'astro:transitions';
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>l8p tech — Proposta de Patrocínio Fundador</title>
    <meta
      name="description"
      content="Proposta de Patrocínio Fundador para o canal l8p tech — ConfrariaTech"
    />
    <meta name="robots" content="noindex, nofollow" />
    <meta property="og:title" content="l8p tech — Proposta de Patrocínio Fundador" />
    <meta
      property="og:description"
      content="Proposta de parceria para Patrocinador Fundador do canal l8p tech"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />

    <style is:global>
      :root {
        --bg: #e9e5df;
        --surface: #efece7;
        --surface2: #e3ded8;
        --border: rgba(0, 0, 0, 0.08);
        --text: #2a2520;
        --text-muted: #524e49;
        --text-dim: #8c8680;
        --accent: #4b44e8;
        --accent-glow: rgba(75, 68, 232, 0.07);
        --accent2: #e85a1a;
        --green: #16a34a;
        --radius: 12px;
        --radius-sm: 8px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
        font-size: 17px;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', sans-serif;
        font-weight: 400;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      /* TOPBAR */
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2.5rem;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: rgba(233, 229, 223, 0.93);
        backdrop-filter: blur(12px);
        z-index: 100;
      }

      .topbar-logo {
        font-family: 'Geist', sans-serif;
        font-weight: 800;
        font-size: 1.25rem;
        letter-spacing: -0.03em;
        color: var(--text);
      }

      .topbar-badge {
        background: rgba(255, 107, 53, 0.15);
        border: 1px solid rgba(255, 107, 53, 0.3);
        color: var(--accent2);
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        padding: 0.3rem 0.8rem;
        border-radius: 100px;
        text-transform: uppercase;
      }

      /* CONTAINER */
      .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 2.5rem;
      }

      /* HERO */
      .hero {
        padding: 5rem 0 4rem;
        border-bottom: 1px solid var(--border);
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--accent-glow);
        border: 1px solid rgba(108, 99, 255, 0.3);
        border-radius: 100px;
        padding: 0.3rem 0.9rem;
        font-size: 0.7rem;
        font-weight: 500;
        color: var(--accent);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 2rem;
      }

      .hero-eyebrow::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
        animation: pulse 2s infinite;
      }

      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.3;
        }
      }

      .hero-title {
        font-family: 'Geist', sans-serif;
        font-weight: 800;
        font-size: clamp(1.75rem, 3.5vw, 2.5rem);
        line-height: 1.1;
        letter-spacing: -0.03em;
        color: var(--text);
        margin-bottom: 1.2rem;
        max-width: 780px;
      }

      .hero-title .accent {
        color: var(--accent);
      }
      .hero-title .dim {
        color: var(--text-muted);
      }

      .hero-subtitle {
        font-size: 1rem;
        color: var(--text-muted);
        max-width: 560px;
        line-height: 1.75;
        margin-bottom: 3rem;
      }

      .hero-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border: 1.5px solid rgba(0, 0, 0, 0.18);
        border-radius: var(--radius);
        overflow: hidden;
        background: rgba(0, 0, 0, 0.18);
        width: 100%;
      }

      .hero-stat {
        padding: 1.2rem 1rem;
        background: var(--surface);
        border-right: 1.5px solid rgba(0, 0, 0, 0.18);
        text-align: center;
      }

      .hero-stat:last-child {
        border-right: none;
      }

      .hero-stat-value {
        font-family: 'Geist', sans-serif;
        font-weight: 800;
        font-size: 1.8rem;
        color: var(--text);
        display: block;
        letter-spacing: -0.03em;
      }

      .hero-stat-label {
        font-size: 0.7rem;
        color: var(--text-muted);
        display: block;
        margin-top: 0.2rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      /* SECTION */
      .section {
        padding: 4rem 0;
        border-bottom: 1px solid var(--border);
      }

      .section-label {
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.6rem;
      }

      .section-title {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 1.35rem;
        letter-spacing: -0.02em;
        color: var(--text);
        margin-bottom: 0.8rem;
        line-height: 1.25;
      }

      .section-body {
        font-size: 0.93rem;
        color: var(--text-muted);
        max-width: 640px;
        line-height: 1.8;
        margin-bottom: 2rem;
      }

      /* CARDS GRID */
      .cards-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
      }

      .card {
        background: var(--surface);
        padding: 1.6rem;
      }

      .card-icon {
        width: 36px;
        height: 36px;
        background: var(--accent-glow);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        margin-bottom: 1rem;
      }

      .card h4 {
        font-family: 'Geist', sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--text);
        margin-bottom: 0.4rem;
      }

      .card p {
        font-size: 0.83rem;
        color: var(--text-muted);
        line-height: 1.6;
      }

      /* SCHEDULE */
      .schedule {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.75rem;
        margin-top: 2rem;
      }

      .schedule-day {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        padding: 1.4rem 1.1rem 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0;
        position: relative;
        overflow: hidden;
        transition:
          transform 0.15s,
          box-shadow 0.15s;
      }

      .schedule-day:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.07);
      }

      .schedule-day::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
      }

      .schedule-day:nth-child(1)::before {
        background: #4b44e8;
      }
      .schedule-day:nth-child(2)::before {
        background: #e85a1a;
      }
      .schedule-day:nth-child(3)::before {
        background: #16a34a;
      }
      .schedule-day:nth-child(4)::before {
        background: #0ea5e9;
      }
      .schedule-day:nth-child(5)::before {
        background: #9333ea;
      }

      .schedule-day-name {
        font-size: 0.6rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-dim);
        margin-bottom: 1rem;
        margin-top: 0.3rem;
      }

      .schedule-day-emoji {
        font-size: 1.6rem;
        display: block;
        margin-bottom: 0.75rem;
        line-height: 1;
      }

      .schedule-day-title {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 0.88rem;
        color: var(--text);
        margin-bottom: 0.5rem;
        line-height: 1.2;
      }

      .schedule-day-desc {
        font-size: 0.75rem;
        color: var(--text-muted);
        line-height: 1.55;
        flex: 1;
      }

      .schedule-day-tag {
        display: inline-block;
        margin-top: 1rem;
        font-size: 0.6rem;
        font-weight: 600;
        color: var(--text-dim);
        background: var(--surface2);
        border-radius: 100px;
        padding: 0.2rem 0.6rem;
        letter-spacing: 0.04em;
        width: fit-content;
      }

      .schedule-disclaimer {
        margin-top: 1rem;
        font-size: 0.72rem;
        color: var(--text-dim);
        font-style: italic;
        padding-left: 0.2rem;
      }

      /* CREATOR */
      .creator-block {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 2.5rem;
        margin-top: 2rem;
        align-items: start;
      }

      .creator-image {
        width: 100%;
        aspect-ratio: 3/4;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 0.6rem;
        position: relative;
      }

      .creator-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .creator-image-label {
        font-size: 0.68rem;
        color: var(--text-dim);
        text-align: center;
        padding: 0 1.2rem;
        line-height: 1.5;
      }

      .creator-image-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--surface2);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
      }

      .creator-info {
        display: flex;
        flex-direction: column;
        gap: 1.4rem;
      }

      .creator-name {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        letter-spacing: -0.03em;
        color: var(--text);
        margin-bottom: 0.2rem;
      }

      .creator-role {
        font-size: 0.78rem;
        color: var(--text-muted);
      }

      .creator-bio {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.75;
      }

      .creator-metrics {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        overflow: hidden;
      }

      .creator-metric {
        background: var(--surface);
        padding: 0.9rem 0.8rem;
        text-align: center;
      }

      .creator-metric-value {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 1.2rem;
        color: var(--text);
        display: block;
        letter-spacing: -0.02em;
      }

      .creator-metric-label {
        font-size: 0.62rem;
        color: var(--text-dim);
        display: block;
        margin-top: 0.2rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .social-channels {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .social-channel {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 0.85rem 1.1rem;
        transition:
          border-color 0.2s,
          background 0.2s;
      }

      .social-channel:hover {
        border-color: rgba(108, 99, 255, 0.4);
        background: var(--surface2);
        text-decoration: none;
      }

      .social-channel-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
      }

      .social-channel-icon.ig {
        background: linear-gradient(
          135deg,
          #f09433 0%,
          #e6683c 25%,
          #dc2743 50%,
          #cc2366 75%,
          #bc1888 100%
        );
      }

      .social-channel-icon.tt {
        background: #010101;
        border: 1px solid #2a2a2a;
      }

      .social-channel-info {
        flex: 1;
        min-width: 0;
      }

      .social-channel-name {
        font-family: 'Geist', sans-serif;
        font-weight: 600;
        font-size: 0.82rem;
        color: var(--text);
        display: block;
      }

      .social-channel-handle {
        font-size: 0.7rem;
        color: var(--text-muted);
        display: block;
        margin-top: 0.1rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .social-channel-stat {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 0.88rem;
        color: var(--green);
        flex-shrink: 0;
      }

      .social-channel-arrow {
        font-size: 0.75rem;
        color: var(--text-dim);
        flex-shrink: 0;
        margin-left: 0.3rem;
      }

      /* OFFER */
      .offer-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        margin-top: 2rem;
      }

      .offer-header {
        background: var(--accent);
        padding: 1.4rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .offer-header-title {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        color: white;
      }

      .offer-header-sub {
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.7);
        margin-top: 0.2rem;
      }

      .offer-price {
        font-family: 'Geist', sans-serif;
        font-weight: 800;
        font-size: 2rem;
        color: white;
        letter-spacing: -0.04em;
        line-height: 1;
        text-align: right;
      }

      .offer-price-sub {
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.65);
        display: block;
        margin-top: 0.2rem;
        text-align: right;
      }

      .offer-body {
        padding: 2rem;
      }

      .offer-items {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem;
        margin-bottom: 2rem;
      }

      .offer-item {
        display: flex;
        align-items: flex-start;
        gap: 0.7rem;
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.5;
      }

      .offer-item-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
        margin-top: 0.45rem;
      }

      .offer-why {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-sm);
        padding: 1.2rem 1.4rem;
        margin-bottom: 2rem;
      }

      .offer-why h4 {
        font-family: 'Geist', sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--text);
        margin-bottom: 0.5rem;
      }

      .offer-why p {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.7;
      }

      .offer-deadline {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        padding-top: 1.4rem;
        border-top: 1px solid var(--border);
      }

      .offer-deadline-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-dim);
        margin-bottom: 0.3rem;
      }

      .offer-deadline-date {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 1.25rem;
        color: var(--accent2);
      }

      .offer-deadline-sub {
        font-size: 0.72rem;
        color: var(--text-dim);
        margin-top: 0.2rem;
      }

      .offer-slots {
        display: flex;
        gap: 0.4rem;
        align-items: center;
      }

      .slot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }

      .slot.taken {
        background: var(--accent);
      }
      .slot.open {
        background: transparent;
        border: 1px solid var(--text-dim);
      }
      .slot-label {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-left: 0.3rem;
      }

      /* STEPS / TIMELINE */
      .steps {
        margin-top: 2.5rem;
        position: relative;
        padding-left: 1.2rem;
      }

      .steps::before {
        content: '';
        position: absolute;
        left: calc(1.2rem + 0.95rem);
        top: 0.95rem;
        bottom: 1rem;
        width: 1px;
        background: linear-gradient(to bottom, var(--accent), var(--border));
        opacity: 0.35;
      }

      .step {
        display: grid;
        grid-template-columns: 2rem 1fr;
        gap: 1.2rem;
        padding-bottom: 2rem;
        align-items: start;
        position: relative;
      }

      .step:last-child {
        padding-bottom: 0;
      }

      .step-num {
        font-family: 'Geist', sans-serif;
        font-weight: 700;
        font-size: 0.65rem;
        color: white;
        background: var(--accent);
        border-radius: 50%;
        width: 1.9rem;
        height: 1.9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        position: relative;
        z-index: 1;
        box-shadow: 0 0 0 3px var(--bg);
      }

      .step:nth-child(n + 2) .step-num {
        background: var(--surface2);
        color: var(--text-muted);
        border: 1px solid var(--border);
      }

      .step-body {
        padding-top: 0.2rem;
      }

      .step h4 {
        font-family: 'Geist', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text);
        margin-bottom: 0.25rem;
        line-height: 1.3;
      }

      .step p {
        font-size: 0.8rem;
        color: var(--text-muted);
        line-height: 1.65;
      }

      /* METAS */
      .metas {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        margin-top: 2rem;
      }

      .meta {
        background: var(--surface);
        padding: 2rem 1.5rem;
        text-align: center;
      }

      .meta-num {
        font-family: 'Geist', sans-serif;
        font-weight: 800;
        font-size: 3rem;
        color: var(--text);
        display: block;
        letter-spacing: -0.04em;
        line-height: 1;
      }

      .meta-label {
        font-size: 0.72rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        display: block;
        margin-top: 0.5rem;
      }

      .meta-note {
        font-size: 0.72rem;
        color: var(--text-dim);
        margin-top: 0.3rem;
        font-style: italic;
      }

      /* LOGOS GRID */
      .logos-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
      }

      .logo-slot {
        background: var(--surface);
        aspect-ratio: 2/1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        transition: background 0.15s;
        text-decoration: none;
        color: inherit;
      }

      .logo-slot:hover {
        background: var(--surface2);
      }

      .logo-slot img {
        max-width: 100%;
        max-height: 32px;
        object-fit: contain;
        filter: grayscale(1);
        opacity: 0.7;
        transition:
          opacity 0.15s,
          filter 0.15s;
      }

      .logo-slot:hover img {
        filter: grayscale(0);
        opacity: 1;
      }

      .logo-slot span {
        font-size: 0.82rem;
        color: var(--text-muted);
        text-align: center;
        font-family: 'Geist', sans-serif;
        font-weight: 600;
        letter-spacing: 0.04em;
      }

      /* AUDIENCE */
      .audience-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .audience-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.4rem;
      }

      .audience-card-wide {
        grid-column: span 2;
      }

      .audience-card-label {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: 1.1rem;
        font-family: 'Geist', sans-serif;
      }

      .audience-bar-group {
